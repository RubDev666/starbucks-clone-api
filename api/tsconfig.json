{
  "compilerOptions": {
    "target": "es2016",
     "module": "commonjs",
      "outDir": "./dist",
      "rootDir": "./src",
     "esModuleInterop": true,
     "forceConsistentCasingInFileNames": true,
      "strict": true,
     "skipLibCheck": true,
      "sourceMap": true,
      "resolveJsonModule": true
   },
   "include": ["src/**/*", "swagger.json"],
   "exclude": ["node_modules", "dist"]
}